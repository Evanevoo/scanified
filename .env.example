# Canonical site URL (https://www.scanified.com in production). Used for SEO meta, emails, and deep links.
# VITE_SITE_URL=https://www.scanified.com
#
# Netlify Functions: set SITE_URL to the same origin (Dashboard → Environment). Used for auth email redirects.
# SITE_URL=https://www.scanified.com
#
# If the web app is hosted somewhere other than Netlify but functions stay on Netlify, set:
# VITE_NETLIFY_FUNCTIONS_BASE_URL=https://your-site.netlify.app
#
# QuickBooks Web Connector — GET https://www.scanified.com/qwc is served by netlify/functions/qwc.js
# Set these in Netlify Dashboard → Environment (not in this file for production):
# QBWC_APP_URL=https://scanified-qbwc.onrender.com/soap
# (use your real Render URL + /soap — see render.yaml and qbwc-server/README.md)
# QBWC_SUPPORT_URL=https://www.scanified.com/support
# QBWC_USERNAME=scanified
# QBWC_OWNER_ID=<stable-guid>
# QBWC_FILE_ID=<stable-guid>

# Scanbot SDK license key (for ScanbotTest screen). Add SCANBOT_SDK_LICENSE_KEY to .env with your key.
# The key can include newlines; in .env use \n for newlines inside double quotes, e.g.:
# SCANBOT_SDK_LICENSE_KEY="part1\nU2NhbmJvdFNES...\n"
# SCANBOT_SDK_LICENSE_KEY=
