# HTTP
PORT=8090
# Path mounted by node-soap (must match AppURL in the .qwc file)
SOAP_PATH=/soap

# Public URL QuickBooks Web Connector can reach (use ngrok/Cloudflare Tunnel in dev)
PUBLIC_BASE_URL=http://127.0.0.1:8090

# Shown in the generated .qwc file
APP_SUPPORT_URL=https://www.scanified.com/support

# Credentials in the .qwc file (UserName) and authenticate()
QBWC_USERNAME=scanified
QBWC_PASSWORD=change-me

# Stable GUIDs — set once per deployment so QBWC does not treat the app as a new registration
# QBWC_OWNER_ID=
# QBWC_FILE_ID=
